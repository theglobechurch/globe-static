{% comment %}
  Why is this a liquid template and the rest nunjucks?
  Because the async shortcode (rwdImg) does not play nicely via an
  include in nunjucks… but it does in liquid. And 11ty is happy with
  either templating system.
{% endcomment %}

<a
  href="/{{ cardContent.url }}"
  class="card card--link"
>
  <div class="card__img">
    {% if cardContent.featured_img_url %}
      {% rwdImg cardContent.featured_img_url, "", "400,600,850", "", "(min-width: 640px) calc(33vw - 6rem), (min-width: 480px) calc(50vw - 4.5rem), calc(100vw - 4rem)", true, "16:9" %}
    {% else %}
      {% assign randomNum = 1 | randomNumber: 4 %}
      {% assign imgPath = "src/_assets/img/passThrough/placeholder/" | append: randomNum | append: ".jpg" %}
      {% rwdImg imgPath, "", "400,600,850", "", "(min-width: 640px) calc(33vw - 6rem), (min-width: 480px) calc(50vw - 4.5rem), calc(100vw - 4rem)", true, "16:9" %}
    {% endif %}
  </div>

  <div class="card__content">
    <p class="card__title">{{ cardContent.title }}</p>
    <p>{{ cardContent.description }}</p>
    <p class="card__action">More information</p>
  </div>
</a>
