---
---

{% set parentPage = p | pageParent(pages) %}
{% set childPages = p | pageChildren(pages) | sort(false, false, 'menu_order') %}
{% if parentPage %}
{% set siblingPages = parentPage | pageChildren(pages) | sort(false, false, 'menu_order') %}
{% endif %}

<main class="px-4">
  <header class="mx-auto lg:container mb-4">
    {% if p.featured_img_url %}
    <div
      class="sm:aspect-[16/7] w-full sm:bg-cover sm:bg-center sm:overflow-hidden sm:relative"
    >
      {% rwdImg p.featured_img_url, "", [550, 1024, 1512, 2056], "sm:inset-0
      sm:absolute sm:h-full sm:object-cover min-w-full", "100vw", false %}
      <div
        class="px-4 pt-4 sm:absolute sm:inset-0 bg-gradient-to-b from-transparent via-creat/20 to-cream sm:flex sm:flex-col sm:justify-end sm:items-start"
      >
        {% if parentPage %}
        <a href="/{{ parentPage.url }}" class="flex gap-1 items-center group">
          {% svgIcon "icon-arrowLeft", "shrink-0 h-4 w-4 transition
          group-hover:-translate-x-2", "Date" %}
          <span>{{ parentPage.title }}</span>
        </a>
        {% endif %}
        <h1 class="glbHeading">{{ title }}</h1>
      </div>
    </div>
    {% else %} {% if parentPage %}
    <a
      href="/{{ parentPage.url }}"
      class="pt-4 px-4 flex gap-1 items-center group"
    >
      {% svgIcon "icon-arrowLeft", "shrink-0 h-4 w-4 transition
      group-hover:-translate-x-2", "Date" %}
      <span>{{ parentPage.title }}</span>
    </a>
    {% endif %}
    <h1 class="pt-4 px-4 glbHeading">{{ title }}</h1>
    {% endif %}
  </header>

  {% set augLocation = "top" %} {% include 'blocks/augmentedPages.njk' %}

  <div class="mx-auto lg:container">
    <article class="px-4 prose prose-globeBlue">{{ p.body | safe }}</article>
  </div>
</main>

{# Drop in any augmented blocks from 11ty #}
{% set augLocation = "bottom" %}
{% include 'blocks/augmentedPages.njk' %}

{# Keep reading block pulls in parent, child, and sibling pages #}
{% if childPages | length > 0 or parentPage | length > 0 %}
<div class="mt-12 px-4">
  <div class="m-4 mx-auto lg:container">

    <div class="border-b pb-4">
      <h2 class="px-4 glbHeading">Keep reading…</h2>
    </div>

    <div class="card-grid">
      {# Start with child pages… #}
      {% if childPages | length > 0 %}
        {% for page in childPages %}
          {% renderFile "src/_includes/blocks/pageCard.liquid", { cardContent: page } %}
        {% endfor %}
      {% endif %}

      {# Now the parent pages #}
      {% if parentPage %}
        {% renderFile "src/_includes/blocks/pageCard.liquid", { cardContent: parentPage } %}

        {# And finally the sibling pages #}
        {% if siblingPages | length > 0 %}
          {% for page in siblingPages %}
            {# Skip this page… #}
            {% if page.url != p.url %}
              {% renderFile "src/_includes/blocks/pageCard.liquid", { cardContent: page } %}
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}
    </div>
  </div>
</div>
{% endif %}
